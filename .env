# ── Mode ──────────────────────────────────────────
# Set ke True saat deploy ke Render / production
PRODUCTION=False

# ── Django ────────────────────────────────────────
# Ganti dengan nilai random yang panjang sebelum deploy!
# Generate: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-ganti-ini-sebelum-deploy

# Host yang diizinkan (pisah koma). Saat production isi dengan domain Render kamu
# Contoh: footheatscanner.onrender.com,www.footheatscanner.com
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database (hanya dipakai saat PRODUCTION=True) ─
DB_NAME=footheatscanner
DB_USER=postgres
DB_PASSWORD=ganti-dengan-password-db
DB_HOST=localhost
DB_PORT=5432
SCHEMA=public